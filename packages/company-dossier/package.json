  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "osint",
    "company-research",
    "competitive-intelligence",
    "dossier",
    "due-diligence",
    "business-intelligence",
    "company-data",
    "company-profile",
    "wayback",
    "dns-recon",
    "tech-stack",
    "mcp",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ever-just/company-dossier.git",
    "directory": "packages/company-dossier"
  },
  "homepage": "https://companydossier.lol",
  "bugs": {
    "url": "https://github.com/ever-just/company-dossier/issues"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "dossier": "node dist/cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
